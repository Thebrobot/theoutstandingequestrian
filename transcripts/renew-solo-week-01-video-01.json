00, 11, 445, 2684, 264, 7948, 670, 472, 1823, 412, 257, 565, 13, 51600], "temperature": 0.0, "avg_logprob": -0.1503822178516573, "compression_ratio": 1.603448275862069, "no_speech_prob": 0.03288817033171654}, {"id": 42, "seek": 18630, "start": 211.02, "end": 216.02, "text": " You notice immediately when he starts to move, then I snap the whip back and release him", "tokens": [51600, 509, 3449, 4258, 562, 415, 3719, 281, 1286, 11, 550, 286, 13650, 264, 22377, 646, 293, 4374, 796, 51850], "temperature": 0.0, "avg_logprob": -0.1503822178516573, "compression_ratio": 1.603448275862069, "no_speech_prob": 0.03288817033171654}, {"id": 43, "seek": 21602, "start": 216.02, "end": 220.9, "text": " completely from the exercise.", "tokens": [50364, 2584, 490, 264, 5380, 13, 50608], "temperature": 0.0, "avg_logprob": -0.1325659693023305, "compression_ratio": 1.6787564766839378, "no_speech_prob": 0.005334067158401012}, {"id": 44, "seek": 21602, "start": 220.9, "end": 225.58, "text": " And spend time in reward.", "tokens": [50608, 400, 3496, 565, 294, 7782, 13, 50842], "temperature": 0.0, "avg_logprob": -0.1325659693023305, "compression_ratio": 1.6787564766839378, "no_speech_prob": 0.005334067158401012}, {"id": 45, "seek": 21602, "start": 225.58, "end": 231.70000000000002, "text": " If they really enjoy having a walk or if they really enjoy having a pet, spend time there.", "tokens": [50842, 759, 436, 534, 2103, 1419, 257, 1792, 420, 498, 436, 534, 2103, 1419, 257, 3817, 11, 3496, 565, 456, 13, 51148], "temperature": 0.0, "avg_logprob": -0.1325659693023305, "compression_ratio": 1.6787564766839378, "no_speech_prob": 0.005334067158401012}, {"id": 46, "seek": 21602, "start": 231.70000000000002, "end": 237.44, "text": " Talk to them, give them what they need to feel like they've done a good job, especially", "tokens": [51148, 8780, 281, 552, 11, 976, 552, 437, 436, 643, 281, 841, 411, 436, 600, 1096, 257, 665, 1691, 11, 2318, 51435], "temperature": 0.0, "avg_logprob": -0.132565969302330