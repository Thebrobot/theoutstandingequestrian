---
import { navLinks } from "../../data/navLinks";
import CTAButton from "../CTAButton.astro";
import Logo from "./Logo.astro";

interface Props {
  activeHref?: string;
}

const { activeHref = Astro.url.pathname } = Astro.props;
---

<header class="sticky top-0 z-40 bg-white border-b border-plum/10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-[4.5rem]">
      <Logo />
      <nav class="hidden md:flex items-center gap-10">
        {
          navLinks.map((link) => {
            const isActive = activeHref === link.href || (link.href !== "/" && activeHref.startsWith(link.href));
            return (
              <a
                href={link.href}
                class:list={["nav-link-serif", isActive && "nav-link-serif-active"]}
              >
                {link.label}
                {isActive && <span class="nav-serif-diamond" aria-hidden="true"></span>}
              </a>
            );
          })
        }
        <CTAButton href="/enroll" variant="primary" size="sm">
          Enroll Now
        </CTAButton>
      </nav>
    </div>
  </div>
</header>

<div class="relative min-h-[220px] flex items-end bg-cream px-6 py-10">
  <p class="font-serif text-2xl text-plum">
    Serif links with <span class="text-gold italic">gold diamond</span> active marker
  </p>
</div>
<div class="min-h-[200px] bg-white px-6 py-10">
  <p class="text-charcoal/70 max-w-md">
    Playfair Display navigation with the same diamond motif as your section dividers.
  </p>
</div>
