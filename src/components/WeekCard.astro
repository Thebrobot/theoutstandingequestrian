---
interface Props {
  number: number;
  title: string;
  teaser: string;
  locked?: boolean;
}

const { number, title, teaser, locked = false } = Astro.props;
const paddedNumber = String(number).padStart(2, "0");
---

<div class="group relative bg-white rounded-2xl border border-plum/10 p-6 shadow-sm card-lift overflow-hidden">
  <span
    class="absolute -right-2 -bottom-4 font-serif text-8xl font-bold text-plum/[0.06] select-none pointer-events-none leading-none"
    aria-hidden="true"
  >
    {paddedNumber}
  </span>
  {
    locked && (
      <div class="absolute top-4 right-4 text-plum/25 group-hover:text-gold/60 transition-colors" aria-hidden="true">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
          <path
            fill-rule="evenodd"
            d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z"
            clip-rule="evenodd"></path>
        </svg>
      </div>
    )
  }
  <div class="relative">
    <p class="text-xs font-bold text-gold uppercase tracking-[0.15em] mb-2">
      Week {number}
    </p>
    <h3 class="font-serif text-xl font-bold text-charcoal mb-2 pr-8 group-hover:text-plum transition-colors">
      {title}
    </h3>
    <p class="text-charcoal/70 text-sm leading-relaxed">{teaser}</p>
  </div>
</div>
