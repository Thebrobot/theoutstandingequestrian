---
import { formatBlogDate, type BlogPost } from "../data/blog";

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

const categoryColors: Record<BlogPost["category"], string> = {
  Groundwork: "bg-plum/10 text-plum",
  Mounted: "bg-gold/15 text-charcoal",
  Mindset: "bg-cream-dark text-plum-dark",
};
---

<article class="card-lift bg-white rounded-xl border border-plum/10 overflow-hidden shadow-sm h-full flex flex-col">
  <a href={`/blog/${post.slug}`} class="block group">
    <div class="aspect-video overflow-hidden bg-cream-dark">
      <img
        src={post.image}
        alt={post.imageAlt}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
      />
    </div>
  </a>

  <div class="p-6 sm:p-7 flex flex-col flex-1">
    <div class="flex items-center gap-3 mb-4">
      <span class:list={["text-xs font-semibold uppercase tracking-wide rounded-full px-3 py-1", categoryColors[post.category]]}>
        {post.category}
      </span>
      <span class="text-sm text-charcoal/50">{post.readTime}</span>
    </div>

    <h2 class="font-serif text-xl sm:text-2xl font-bold text-charcoal mb-3 leading-snug">
      <a href={`/blog/${post.slug}`} class="hover:text-plum transition-colors">
        {post.title}
      </a>
    </h2>

    <p class="text-charcoal/70 leading-relaxed mb-5 flex-1">{post.excerpt}</p>

    <div class="flex items-center justify-between pt-4 border-t border-plum/10">
      <time datetime={post.publishedAt} class="text-sm text-charcoal/50">
        {formatBlogDate(post.publishedAt)}
      </time>
      <a
        href={`/blog/${post.slug}`}
        class="text-sm font-semibold text-plum hover:text-gold transition-colors"
      >
        Read article &rarr;
      </a>
    </div>
  </div>
</article>
