---
import { BRAND_NAME } from "../config";
import { navLinks } from "../data/navLinks";
import Logo from "./nav/Logo.astro";

const year = new Date().getFullYear();
const footerLinks = [...navLinks, { href: "/enroll", label: "Enroll" }];
---

<footer id="stay-in-loop" class="section-plum text-white/80 mt-auto scroll-mt-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
    <!-- Newsletter band -->
    <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-5 lg:gap-10 pb-6">
      <div class="shrink-0 lg:max-w-xs">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-1.5">Stay connected</p>
        <h2 class="font-serif text-xl sm:text-2xl font-bold text-white mb-1">Stay in the loop</h2>
        <p class="text-sm text-cream/70 leading-relaxed">
          Training tips and course updates, straight to your inbox.
        </p>
      </div>

      <div class="w-full lg:max-w-md lg:shrink-0">
        <form id="footer-waitlist-form" class="flex flex-col sm:flex-row gap-2" novalidate>
          <input
            type="email"
            id="footer-waitlist-email"
            name="email"
            placeholder="Email address"
            required
            autocomplete="email"
            class="flex-1 min-w-0 rounded-full px-4 py-2 text-sm text-charcoal bg-white/95 placeholder:text-charcoal/40 focus:outline-none focus:ring-2 focus:ring-gold/50"
          />
          <button
            type="submit"
            id="footer-waitlist-btn"
            class="bg-gold text-charcoal text-sm font-semibold rounded-full px-5 py-2 hover:bg-gold/90 transition-colors shrink-0"
          >
            Subscribe
          </button>
        </form>
        <p id="footer-waitlist-error" class="hidden mt-2 text-red-300 text-xs"></p>
        <p id="footer-waitlist-success" class="hidden mt-2 text-gold text-xs font-medium">
          You&apos;re on the list! Check your inbox soon.
        </p>
      </div>
    </div>

    <div class="section-divider mb-6" aria-hidden="true">
      <span></span>
    </div>

    <!-- Links band -->
    <div class="flex flex-col gap-5 sm:flex-row sm:items-center sm:justify-between pb-5">
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
        <Logo theme="light" class="shrink-0 scale-95 origin-left" />
        <nav aria-label="Footer" class="flex flex-wrap items-center gap-x-3 gap-y-1 text-sm">
          {
            footerLinks.map((link, index) => (
              <>
                {index > 0 && <span class="hidden sm:inline text-white/25 select-none" aria-hidden="true">·</span>}
                <a href={link.href} class="hover:text-gold transition-colors">
                  {link.label}
                </a>
              </>
            ))
          }
        </nav>
      </div>

      <a
        href="https://instagram.com"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center w-9 h-9 rounded-full border border-white/15 text-white/70 hover:text-gold hover:border-gold/40 transition-colors shrink-0 self-start sm:self-auto"
        aria-label="Instagram"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path
            d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
          ></path>
        </svg>
      </a>
    </div>

    <p class="text-xs text-white/40 text-center sm:text-left">
      &copy; {year} {BRAND_NAME}. All rights reserved.
    </p>
  </div>
</footer>

<script>
  const waitlistForm = document.getElementById("footer-waitlist-form");
  const waitlistBtn = document.getElementById("footer-waitlist-btn");
  const waitlistError = document.getElementById("footer-waitlist-error");
  const waitlistSuccess = document.getElementById("footer-waitlist-success");
  const waitlistEmail = document.getElementById("footer-waitlist-email");

  waitlistForm?.addEventListener("submit", async (e) => {
    e.preventDefault();
    waitlistError?.classList.add("hidden");
    waitlistSuccess?.classList.add("hidden");

    const email = (waitlistEmail as HTMLInputElement | null)?.value.trim() ?? "";

    if (!email) {
      if (waitlistError) {
        waitlistError.textContent = "Please enter your email address.";
        waitlistError.classList.remove("hidden");
      }
      return;
    }

    if (waitlistBtn) {
      waitlistBtn.setAttribute("disabled", "true");
      waitlistBtn.textContent = "Subscribing…";
    }

    try {
      const response = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ email }),
      });

      const data = await response.json();

      if (!response.ok) {
        if (waitlistError) {
          waitlistError.textContent = data.error ?? "Something went wrong.";
          waitlistError.classList.remove("hidden");
        }
        return;
      }

      waitlistSuccess?.classList.remove("hidden");
      waitlistForm?.reset();
    } catch {
      if (waitlistError) {
        waitlistError.textContent = "Network error. Please try again.";
        waitlistError.classList.remove("hidden");
      }
    } finally {
      if (waitlistBtn) {
        waitlistBtn.removeAttribute("disabled");
        waitlistBtn.textContent = "Subscribe";
      }
    }
  });
</script>
