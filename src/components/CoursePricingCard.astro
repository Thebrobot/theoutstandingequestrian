---
import type { Course } from "../data/courses";
import CTAButton from "./CTAButton.astro";

interface Props {
  course: Course;
  featured?: boolean;
}

const { course, featured = false } = Astro.props;
const isExternal = course.cta.href.startsWith("mailto:");
---

<article
  class:list={[
    "bg-white rounded-xl border overflow-hidden shadow-sm hover:shadow-md transition-shadow flex flex-col h-full",
    featured ? "border-plum ring-2 ring-plum/20" : "border-gray-200",
  ]}
>
  <div class="aspect-[4/3] bg-gray-200 overflow-hidden">
    <img
      src={course.thumbnail}
      alt={course.title}
      class="w-full h-full object-cover"
      loading="lazy"
    />
  </div>
  <div class="p-6 sm:p-8 flex flex-col flex-1">
    {
      course.highlight && (
        <p class="text-sm font-semibold text-plum mb-1">{course.highlight}</p>
      )
    }
    <h3 class="font-serif text-2xl sm:text-3xl font-bold text-charcoal mb-1">{course.title}</h3>
    {
      course.price && (
        <p class="mb-4">
          <span class="text-3xl font-bold text-charcoal">{course.price}</span>
          {course.priceNote && (
            <span class="text-charcoal/60 text-sm ml-1">{course.priceNote}</span>
          )}
        </p>
      )
    }
    {
      course.subtitle && !course.highlight && (
        <p class="text-charcoal/70 text-sm font-medium mb-4">{course.subtitle}</p>
      )
    }
    <ul class="space-y-2 mb-6 flex-1">
      {
        course.features.map((feature) => (
          <li class="flex gap-2 text-sm text-charcoal/80">
            <svg
              class="w-4 h-4 text-gold shrink-0 mt-0.5"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fill-rule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z"
                clip-rule="evenodd"
              />
            </svg>
            {feature}
          </li>
        ))
      }
    </ul>
    <p class="text-xs text-charcoal/60 mb-5">
      <span class="font-semibold text-charcoal/80">Best for:</span> {course.bestFor}
    </p>
    {
      isExternal ? (
        <a
          href={course.cta.href}
          class="inline-block w-full text-center font-semibold rounded-lg transition-colors px-6 py-3 bg-plum text-white hover:bg-plum-dark"
        >
          {course.cta.label}
        </a>
      ) : (
        <CTAButton href={course.cta.href} variant="primary" class="w-full text-center">
          {course.cta.label}
        </CTAButton>
      )
    }
    <a
      href={`/courses/${course.slug}`}
      class="mt-3 text-center text-sm text-plum font-medium hover:text-plum-dark transition-colors"
    >
      Learn more
    </a>
  </div>
</article>
