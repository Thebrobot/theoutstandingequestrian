---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroVideo from "../components/HeroVideo.astro";
import CTAButton from "../components/CTAButton.astro";
import SectionHeader from "../components/SectionHeader.astro";
import WeekCard from "../components/WeekCard.astro";
import TestimonialCard from "../components/TestimonialCard.astro";
import { weeks } from "../data/weeks";
import { testimonials } from "../data/testimonials";
import { INSTRUCTOR_NAME, BRAND_NAME } from "../config";
---

<BaseLayout
  title="Home"
  description="Stop guessing. Start growing. Structured equestrian training for solo riders."
  preloadVideo="/videos/dressage-hero.mp4"
  preloadPoster="/videos/dressage-hero-poster.jpg"
>
  <!-- Hero -->
  <section id="page-hero" class="relative text-white overflow-hidden min-h-[90vh] flex items-center">
    <HeroVideo
      mp4="/videos/dressage-hero.mp4"
      webm="/videos/dressage-hero.webm"
      poster="/videos/dressage-hero-poster.jpg"
    />
    <div
      class="absolute inset-0 bg-gradient-to-r from-plum/90 via-plum/75 to-plum/50"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_20%_80%,rgba(201,168,76,0.2),transparent_50%)]"
      aria-hidden="true"
    >
    </div>
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_90%_10%,rgba(201,168,76,0.12),transparent_40%)]"
      aria-hidden="true"
    >
    </div>
    <div class="hero-content max-w-6xl mx-auto px-4 sm:px-6 pb-18 sm:pb-24 w-full text-center">
      <div class="max-w-2xl mx-auto">
        <p
          class="inline-flex items-center gap-2 text-xs sm:text-sm tracking-wide uppercase bg-gold text-charcoal font-semibold rounded-full px-3 py-1.5 mb-5"
        >
          <span class="w-2 h-2 rounded-full bg-plum"></span>
          Enrollment currently open
        </p>
        <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-bold leading-tight mb-6">
          Stop Guessing.<br />
          <span class="text-gold">Start Growing.</span>
        </h1>
        <p class="text-lg sm:text-xl text-cream/90 mb-8 leading-relaxed">
          A six-week program that teaches you to ride with intention, communicate clearly with
          your horse, and build real progress even when you train alone.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mb-6 justify-center">
          <CTAButton href="/enroll" variant="gold" size="lg">Claim Your Spot</CTAButton>
          <CTAButton href="#course-preview" variant="light" size="lg">
            Explore the Program
          </CTAButton>
        </div>
        <div class="grid grid-cols-3 gap-4 max-w-lg mx-auto pt-4 border-t border-gold/30">
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-gold">100+</p>
            <p class="text-cream/80 text-xs sm:text-sm">Riders coached</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-gold">6</p>
            <p class="text-cream/80 text-xs sm:text-sm">Weeks structured</p>
          </div>
          <div>
            <p class="text-2xl sm:text-3xl font-bold text-gold">3</p>
            <p class="text-cream/80 text-xs sm:text-sm">Core pillars</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Proof Strip -->
  <section class="bg-cream bg-grain py-14 sm:py-16 border-y border-plum/10">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="relative grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="hidden md:block absolute top-12 left-[20%] right-[20%] h-px bg-gradient-to-r from-transparent via-gold/40 to-transparent"
          aria-hidden="true"
        >
        </div>

        <div class="proof-card">
          <div class="proof-card-icon" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-2">Built For</p>
          <p class="font-serif text-xl font-bold text-plum leading-snug mb-2">
            Riders across every discipline
          </p>
          <p class="text-sm text-charcoal/70 leading-relaxed">
            Dressage, eventing, and hunter/jumper, structured for solo riders and adult amateurs.
          </p>
        </div>

        <div class="proof-card md:translate-y-3">
          <div class="proof-card-icon" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-2">Training Style</p>
          <p class="font-serif text-xl font-bold text-plum leading-snug mb-2">
            Reward-based &amp; practical
          </p>
          <p class="text-sm text-charcoal/70 leading-relaxed">
            Clear instruction you can apply in your very next ride, with no jargon and no guesswork.
          </p>
        </div>

        <div class="proof-card">
          <div class="proof-card-icon" aria-hidden="true">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-gold mb-2">Outcome</p>
          <p class="font-serif text-xl font-bold text-plum leading-snug mb-2">
            Progress you can feel
          </p>
          <p class="text-sm text-charcoal/70 leading-relaxed">
            Calmer rides, clearer aids, and consistent week-over-week improvement.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem / Empathy -->
  <section class="section-plum py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div>
          <SectionHeader
            eyebrow="Sound familiar?"
            heading="You love your horse. You're putting in the rides. But something isn't clicking."
            theme="dark"
          />
          <p class="mt-6 text-lg text-cream/85 leading-relaxed">
            Renew SOLO gives you a structured path: groundwork, riding, and mental fitness, so every
            session has a purpose and every week builds on the last.
          </p>
          <p class="mt-4 font-serif italic text-gold text-xl leading-relaxed">
            You don&apos;t need more random tips. You need a system that actually sticks.
          </p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <blockquote class="pain-quote sm:col-span-2">
            <p>I reach for the rein, even when I know the answer should come from my leg.</p>
          </blockquote>
          <blockquote class="pain-quote">
            <p>I feel the stress building in the saddle, even when I know better.</p>
          </blockquote>
          <blockquote class="pain-quote">
            <p>My rewards are all over the place, and my horse isn&apos;t sure what I&apos;m asking.</p>
          </blockquote>
          <blockquote class="pain-quote">
            <p>I show up to ride without thinking about how my horse&apos;s day, or body, is feeling.</p>
          </blockquote>
          <blockquote class="pain-quote">
            <p>I&apos;m guessing at pole distances and wondering why my progress feels so slow.</p>
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Free Training -->
  <section class="section-white py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
        <div class="order-2 lg:order-1">
          <div class="relative">
            <div
              class="absolute -inset-3 bg-plum/10 rounded-2xl -rotate-2 -z-10"
              aria-hidden="true"
            >
            </div>
            <div class="rounded-2xl overflow-hidden border-2 border-plum/15 shadow-xl">
              <img
                src="/images/oe-hero-training.png"
                alt="Rider working with a calm horse in an outdoor arena"
                class="aspect-[4/5] sm:aspect-[16/12] w-full object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold mb-2">Free training</p>
          <h2 class="font-serif text-3xl sm:text-4xl font-bold text-charcoal mb-4 leading-tight">
            Ride with more clarity <span class="italic text-plum">this week</span>
          </h2>
          <p class="text-charcoal/70 leading-relaxed mb-6">
            Start with a free mini-training on leg-to-hand connection and intentional warm-ups.
            Build confidence before you commit to the full program.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <CTAButton href="#stay-in-loop" variant="gold">Get Free Training</CTAButton>
            <CTAButton href="/enroll" variant="secondary">See Full Program</CTAButton>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Method -->
  <section class="section-plum py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <SectionHeader
        eyebrow="The method"
        heading="Learn → Practice → Progress"
        subtext="Three steps, repeated every week, that turn instruction into real improvement."
        align="center"
        decorative={true}
        theme="dark"
        class="mb-14"
      />
      <div class="relative grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6">
        <div
          class="hidden md:block absolute top-10 left-[18%] right-[18%] h-px bg-gradient-to-r from-transparent via-gold/50 to-transparent"
          aria-hidden="true"
        >
        </div>
        <div class="method-step mt-4 md:mt-0" data-step="1">
          <h3 class="font-serif text-xl font-bold text-charcoal mb-2 pt-2">Learn</h3>
          <p class="text-charcoal/70 text-sm leading-relaxed">
            Watch clear video lessons covering groundwork, mounted exercises, and mental fitness for
            the week.
          </p>
        </div>
        <div class="method-step mt-4 md:mt-0" data-step="2">
          <h3 class="font-serif text-xl font-bold text-charcoal mb-2 pt-2">Practice</h3>
          <p class="text-charcoal/70 text-sm leading-relaxed">
            Take each exercise to your barn. Work at your own pace with reward-based training
            tailored to your horse.
          </p>
        </div>
        <div class="method-step mt-4 md:mt-0" data-step="3">
          <h3 class="font-serif text-xl font-bold text-charcoal mb-2 pt-2">Progress</h3>
          <p class="text-charcoal/70 text-sm leading-relaxed">
            Each week builds on the last, from shoulder-over and breath control to jump courses
            and celebration habits that stick.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Offer Stack -->
  <section class="section-white py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <SectionHeader
        eyebrow="Everything included"
        heading="A complete training system, not random tips"
        subtext="Renew SOLO gives you the exact roadmap, accountability tools, and support you need."
        align="center"
        decorative={true}
        class="mb-12"
      />
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl border border-plum/10 p-6 shadow-sm card-lift">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-gold mb-2">Core Program</p>
          <h3 class="font-serif text-xl font-bold text-charcoal mb-3">Six-Week Curriculum</h3>
          <ul class="space-y-2 text-charcoal/75 text-sm">
            <li class="flex gap-2"><span class="text-gold">✦</span> Groundwork and mounted exercises each week</li>
            <li class="flex gap-2"><span class="text-gold">✦</span> Clear focus goals for every ride session</li>
            <li class="flex gap-2"><span class="text-gold">✦</span> Progressive structure that builds confidence</li>
          </ul>
        </div>
        <div class="bg-white rounded-2xl border border-plum/10 p-6 shadow-sm card-lift lg:translate-y-4">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-gold mb-2">Tools</p>
          <h3 class="font-serif text-xl font-bold text-charcoal mb-3">Rider Support Assets</h3>
          <ul class="space-y-2 text-charcoal/75 text-sm">
            <li class="flex gap-2"><span class="text-gold">✦</span> Printable checklists and session planners</li>
            <li class="flex gap-2"><span class="text-gold">✦</span> Mental fitness prompts for consistency</li>
            <li class="flex gap-2"><span class="text-gold">✦</span> Repeatable routines for solo training days</li>
          </ul>
        </div>
        <div class="bg-plum rounded-2xl border-2 border-gold/30 p-6 shadow-lg text-white lg:-translate-y-2">
          <p class="text-xs font-bold uppercase tracking-[0.15em] text-gold mb-2">Bonus</p>
          <h3 class="font-serif text-xl font-bold mb-3">Community and Momentum</h3>
          <ul class="space-y-2 text-white/80 text-sm mb-6">
            <li class="flex gap-2"><span class="text-gold">✦</span> Shared rider wins and accountability</li>
            <li class="flex gap-2"><span class="text-gold">✦</span> Motivation when progress feels slow</li>
            <li class="flex gap-2"><span class="text-gold">✦</span> Guidance to stay consistent through setbacks</li>
          </ul>
          <CTAButton href="/enroll" variant="gold" class="w-full">Enroll in Renew SOLO</CTAButton>
        </div>
      </div>
    </div>
  </section>

  <!-- Course Preview -->
  <section id="course-preview" class="section-plum py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <SectionHeader
        eyebrow="Inside the course"
        heading="Six weeks of structured training"
        subtext="Every week combines groundwork, mounted work, and mental fitness."
        align="center"
        decorative={true}
        theme="dark"
        class="mb-12"
      />
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {weeks.map((week) => (
          <WeekCard
            number={week.number}
            title={week.title}
            teaser={week.teaser}
            locked={true}
          />
        ))}
      </div>
      <div class="text-center mt-10">
        <CTAButton href="/enroll" variant="gold" size="lg">Get Instant Access</CTAButton>
      </div>
    </div>
  </section>

  <!-- Instructor -->
  <section class="section-white py-16 sm:py-24 overflow-hidden">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <div class="relative grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-0 items-center">
        <div class="lg:col-span-5 relative mx-auto lg:mx-0 w-full max-w-xs lg:max-w-none">
          <div
            class="absolute -inset-4 bg-plum/10 rounded-2xl rotate-3"
            aria-hidden="true"
          >
          </div>
          <div class="relative rounded-2xl border-2 border-gold/30 overflow-hidden shadow-xl">
            <img
              src="/images/oe-instructor-portrait.png"
              alt={`${INSTRUCTOR_NAME}, equestrian instructor`}
              class="w-full aspect-[4/5] object-cover"
              loading="lazy"
            />
          </div>
        </div>
        <div class="lg:col-span-7 lg:-ml-10 relative z-10">
          <div class="bg-white rounded-2xl border border-plum/10 p-8 sm:p-10 shadow-lg">
            <p class="text-sm font-semibold uppercase tracking-[0.2em] text-gold mb-2">
              Meet your instructor
            </p>
            <h2 class="font-serif text-3xl font-bold text-charcoal mb-4">{INSTRUCTOR_NAME}</h2>
            <p class="font-serif italic text-plum text-lg leading-relaxed mb-4">
              &ldquo;Every ride starts with intention.&rdquo;
            </p>
            <p class="text-charcoal/70 leading-relaxed mb-5">
              {INSTRUCTOR_NAME} combines classical groundwork, clear mounted progressions, and mental
              fitness, because the best riders train their minds as deliberately as their bodies.
            </p>
            <ul class="space-y-2 text-sm text-charcoal/75">
              <li class="flex gap-2"><span class="text-gold font-bold">✦</span> Structured instruction designed for solo riders</li>
              <li class="flex gap-2"><span class="text-gold font-bold">✦</span> Focused on confidence, timing, and horse-rider communication</li>
              <li class="flex gap-2"><span class="text-gold font-bold">✦</span> Practical tools you can apply in your next ride</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section-plum py-16 sm:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <SectionHeader heading="Riders like you" align="center" decorative={true} theme="dark" class="mb-12" />
      <div class="relative bg-white text-charcoal rounded-2xl p-8 sm:p-10 mb-8 overflow-hidden shadow-xl">
        <div
          class="absolute top-0 right-0 w-48 h-48 bg-plum/10 rounded-full blur-3xl"
          aria-hidden="true"
        >
        </div>
        <p class="text-plum text-xs uppercase tracking-[0.2em] font-semibold mb-3 relative">
          Featured rider story
        </p>
        <blockquote class="editorial-quote font-serif text-xl sm:text-2xl leading-relaxed relative max-w-3xl text-charcoal">
          Before Renew SOLO I felt scattered and second-guessed every ride. Now I have a clear plan
          every week, and my horse feels more relaxed and responsive than ever.
        </blockquote>
        <p class="mt-4 text-charcoal/60 text-sm relative">Adult Amateur, Eventing Rider</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        {testimonials.map((t) => <TestimonialCard {...t} />)}
      </div>
      <div class="relative rounded-2xl border-2 border-gold/20 overflow-hidden shadow-lg">
        <img
          src="/images/oe-community-riders.png"
          alt="Group of riders with their horses in an arena"
          class="aspect-[21/9] w-full object-cover"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-plum/70 via-plum/20 to-transparent flex items-end">
          <p class="p-6 font-serif italic text-white text-lg sm:text-xl">
            A community of riders committed to growing with intention.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Urgency CTA -->
  <section class="section-white py-16 sm:py-20 border-y border-plum/10">
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <p class="text-plum uppercase tracking-[0.2em] text-xs sm:text-sm font-semibold mb-3">
        Limited enrollment window
      </p>
      <h2 class="font-serif text-3xl sm:text-4xl font-bold text-charcoal mb-4 leading-tight">
        Build your confident, consistent training plan <span class="italic text-plum">now</span>
      </h2>
      <p class="text-charcoal/70 mb-8 max-w-2xl mx-auto">
        Join {BRAND_NAME} today and get immediate access to the full six-week system.
      </p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <CTAButton href="/enroll" variant="primary" size="lg">Enroll in Renew SOLO</CTAButton>
        <CTAButton href="#stay-in-loop" variant="secondary" size="lg">
          Join Waitlist Updates
        </CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>
