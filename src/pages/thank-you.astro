---
import BaseLayout from "../layouts/BaseLayout.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout
  title="Thank You"
  description="Your enrollment is confirmed. Check your email for login details."
  minimal={true}
>
  <section class="py-16 sm:py-24">
    <div class="max-w-xl mx-auto px-4 text-center">
      <div class="w-16 h-16 bg-plum/10 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-8 h-8 text-plum" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"
          ></path>
        </svg>
      </div>

      <h1 class="font-serif text-4xl font-bold text-charcoal mb-4">
        You&apos;re in! Check your email.
      </h1>
      <p class="text-lg text-charcoal/70 mb-8 leading-relaxed">
        Your enrollment is confirmed. Check your inbox for login details. Our automation will send
        everything you need to access the course.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <CTAButton href="/" variant="primary">Back to Home</CTAButton>
        <CTAButton href="https://instagram.com" variant="secondary">Follow on Instagram</CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>
