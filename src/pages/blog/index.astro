---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SectionHeader from "../../components/SectionHeader.astro";
import BlogCard from "../../components/BlogCard.astro";
import CTAButton from "../../components/CTAButton.astro";
import { getBlogPostsSorted } from "../../data/blog";
import { COURSE_NAME } from "../../config";

const posts = getBlogPostsSorted();
---

<BaseLayout
  title="Equestrian Training Tips & Insights"
  description="Practical equestrian training insights on groundwork, mounted work, and rider mental fitness — from the team behind the Renew SOLO six-week program."
>
  <section id="page-hero" class="page-hero page-hero--standard section-plum overflow-hidden">
    <div class="hero-content max-w-6xl mx-auto px-4 sm:px-6 w-full">
      <SectionHeader
        eyebrow="Insights"
        heading="Training ideas you can use today"
        subtext="Practical lessons from our six-week Renew SOLO program: groundwork, riding skills, and the mindset work that ties it all together."
        align="center"
        decorative
        theme="dark"
      />
    </div>
  </section>

  <section class="section-white section-pad">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 lg:gap-8">
        {posts.map((post) => <BlogCard post={post} />)}
      </div>

      <div class="mt-12 sm:mt-16 text-center rounded-2xl bg-plum/5 border border-plum/15 p-6 sm:p-10">
        <h2 class="font-serif text-2xl sm:text-3xl font-bold text-charcoal mb-3">
          Want the full structured program?
        </h2>
        <p class="text-charcoal/70 max-w-2xl mx-auto mb-6 leading-relaxed">
          {COURSE_NAME} gives you six weeks of progressive video lessons: groundwork, mounted
          work, and mental fitness designed for solo riders.
        </p>
        <CTAButton href="/enroll" variant="primary" size="lg">
          Enroll Now
        </CTAButton>
      </div>
    </div>
  </section>
</BaseLayout>
