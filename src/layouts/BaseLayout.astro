---
import "../styles/global.css";
import AnnouncementBar from "../components/AnnouncementBar.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import { BRAND_NAME } from "../config";

interface Props {
  title?: string;
  description?: string;
  minimal?: boolean;
  heroNav?: boolean;
  preloadVideo?: string;
  preloadPoster?: string;
}

const {
  title = BRAND_NAME,
  description = "Premium equestrian education for riders who want to grow with intention.",
  minimal = false,
  heroNav = !minimal,
  preloadVideo,
  preloadPoster,
} = Astro.props;

const pageTitle = title === BRAND_NAME ? title : `${title} | ${BRAND_NAME}`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;1,600&display=swap"
      rel="stylesheet"
    />
    <title>{pageTitle}</title>
    {
      preloadPoster && (
        <link rel="preload" as="image" href={preloadPoster} fetchpriority="high" />
      )
    }
    {
      preloadVideo && (
        <link rel="preload" as="video" href={preloadVideo} type="video/mp4" fetchpriority="high" />
      )
    }
  </head>
  <body class:list={["min-h-screen flex flex-col", !minimal && "announcement-visible"]}>
    {minimal ? (
      <header class="border-b border-gray-200 bg-white">
        <div class="max-w-3xl mx-auto px-4 py-4">
          <a href="/" class="font-serif text-xl font-bold text-plum">{BRAND_NAME}</a>
        </div>
      </header>
    ) : (
      <>
        <AnnouncementBar />
        <Nav heroNav={heroNav} />
      </>
    )}
    <main class="flex-1">
      <slot />
    </main>
    {!minimal && <Footer />}
  </body>
</html>
